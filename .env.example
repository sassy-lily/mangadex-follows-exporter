# Copy to .env and fill in. NEVER commit your real .env.
# The names here must match the *_env keys in config.yaml.

# --- MangaDex (source) ---
# username/password are your normal MangaDex login.
# client_id/client_secret come from Settings -> API Clients (see README).
MANGADEX_USERNAME=your-mangadex-username
MANGADEX_PASSWORD=your-mangadex-password
MANGADEX_CLIENT_ID=personal-client-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
MANGADEX_CLIENT_SECRET=your-mangadex-client-secret

# --- MangaUpdates (destination) ---
# Distinct from the MangaDex credentials above. Your MangaUpdates account login.
MANGAUPDATES_USERNAME=your-mangaupdates-username
MANGAUPDATES_PASSWORD=your-mangaupdates-password
